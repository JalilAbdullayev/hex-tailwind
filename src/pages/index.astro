---
import "../styles/global.css";
import HexToTailwind from "../components/HexToTailwind";
import FeedbackForm from "../components/FeedbackForm";
import Link from "../components/Link.astro";
import HexCodeInUrlNotifier from "../components/HexInUrlNotifier";
import ThemeToggle from "../components/ThemeToggle";

const title =
  "Color to Tailwind — Convert HEX, RGB, HSL to Tailwind CSS Colors";
const ogTitle = "Color to Tailwind";
const description =
  "Find the closest Tailwind CSS color for any HEX, RGB, or HSL value. A free online converter with support for Tailwind v1–v4 palettes.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const image = "/meta.webp";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Color to Tailwind" />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={ogTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
      window.localStorage.setItem("theme", theme);
    </script>
  </head>
  <body
    class="min-h-screen overflow-x-hidden font-sans antialiased transition-colors duration-300 bg-linear-to-br from-indigo-50 via-white to-purple-50 text-slate-900 selection:bg-indigo-100 selection:text-indigo-900 dark:from-slate-950 dark:via-slate-900 dark:to-indigo-950 dark:text-slate-100 dark:selection:bg-indigo-500/30 dark:selection:text-indigo-200"
  >
    <ThemeToggle client:load />
    <main class="container p-4 mt-8 mb-24 space-y-8 md:mt-16 md:space-y-12">
      <section class="mb-4 text-center md:mb-12">
        <h1
          class="mb-5 text-5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-linear-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 sm:text-6xl md:text-7xl drop-shadow-sm"
        >
          Color to Tailwind
        </h1>
        <p
          class="mx-auto text-lg leading-relaxed md:text-xl text-slate-600 dark:text-slate-400"
        >
          Convert your color (HEX, RGB, HSL...) to the closest color in the{" "}
          <Link url="https://tailwindcss.com/docs/colors">
            <span
              class="font-semibold text-indigo-500 underline transition-colors hover:text-indigo-600 dark:text-indigo-400 dark:hover:text-indigo-300 decoration-indigo-200 dark:decoration-indigo-900 underline-offset-4"
            >
              Tailwind color palette
            </span>
          </Link>.
        </p>
      </section>
      <HexToTailwind client:load url={canonicalURL.toString()} />
      <HexCodeInUrlNotifier client:only="react" />
      <div class="grid grid-cols-1 gap-8 mt-12 md:grid-cols-2">
        <section
          class="p-8 transition-shadow duration-300 border border-white shadow-xl dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-indigo-100/40 dark:shadow-none rounded-3xl md:p-10 hover:shadow-2xl"
        >
          <h2
            class="mb-5 text-2xl font-bold tracking-tight text-slate-800 dark:text-slate-100"
          >
            How it works
          </h2>
          <div
            class="space-y-4 leading-relaxed text-slate-600 dark:text-slate-400"
          >
            <p>
              Type (or paste) your color code in the input box. We support HEX,
              RGB, HSL, and named colors. The hashtag is optional for hex, so <code
                class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
              >
                #3B82F6
              </code>, <code
                class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
              >
                3B82F6
              </code>, or <code
                class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
              >
                rgb(59, 130, 246)
              </code> work perfectly.
            </p>
            <p>
              We'll instantly calculate the closest Tailwind CSS match using the <span
                class="font-medium text-slate-700 dark:text-slate-300"
                >Delta E algorithm</span
              >
              , which measures the mathematical difference between colors exactly
              as the human eye perceives them.
            </p>
            <p>
              Copy the original color input, the matched HEX, or the Tailwind
              class name with a single click. We also let you know if the
              difference between your color and the Tailwind color is actually
              visible (<span
                class="font-medium text-slate-700 dark:text-slate-300"
                >Delta E > 1</span
              >).
            </p>
          </div>
        </section>
        <section
          class="flex flex-col justify-between p-8 transition-shadow duration-300 border border-white shadow-xl dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-indigo-100/40 dark:shadow-none rounded-3xl md:p-10 hover:shadow-2xl"
        >
          <div>
            <h2
              class="mb-5 text-2xl font-bold tracking-tight text-slate-800 dark:text-slate-100"
            >
              About the project
            </h2>
            <div
              class="space-y-4 leading-relaxed text-slate-600 dark:text-slate-400"
            >
              <p>
                <Link url="https://hextotailwind.com/"> Originally </Link> created
                by
                <Link url="https://github.com/mihailthebuilder/hex-tailwind">
                  Mihail
                </Link>, a software engineer who wanted an easier way to match
                existing brand colors to Tailwind CSS palettes without manually
                eyeballing them.
              </p>
              <h3
                class="mt-4 text-xl font-bold tracking-tight text-slate-800 dark:text-slate-100"
              >
                Why use this version?
              </h3>
              <p>This fork has been supercharged for the modern web:</p>
              <ul class="pl-5 space-y-2 list-disc">
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Extended Color Support:
                  </strong> Supports HEX (3, 4, 6, 8-character), RGB, RGBA, HSL, HSLA,
                  and named CSS colors.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200"
                    >Alpha / Opacity:</strong
                  > Colors with alpha (e.g. <code
                    class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
                  >
                    rgba(59, 130, 246, 0.4)
                  </code> or <code
                    class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
                  >
                    #3B82F666
                  </code>) output Tailwind classes with opacity like <code
                    class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
                  >
                    blue-500/40
                  </code>.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Tailwind v1–v4 Palettes:
                  </strong> Toggle between all four major Tailwind CSS versions with
                  a single click.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Accessibility Checks:
                  </strong> Instantly see the matched color's contrast ratio
                  against white and black text, with WCAG AA/AAA pass or fail
                  badges so UI decisions are safer.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Shade Family + Top 3 Matches:
                  </strong> Instead of only showing one answer, this version
                  previews the entire matched scale and the three nearest
                  Tailwind candidates so you can compare real alternatives.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Smarter Developer Output:
                  </strong> Quick-copy <code
                    class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
                  >
                    bg-
                  </code>, <code
                    class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
                  >
                    text-
                  </code>, and <code
                    class="bg-slate-100 dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 px-1.5 py-0.5 rounded-md font-mono text-sm shadow-sm"
                  >
                    border-
                  </code> classes, arbitrary value fallback suggestions for poor
                  matches, and dark mode complements for faster implementation.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Built-In Color Converter:
                  </strong> The tool also breaks your input into HEX, RGB, HSL,
                  and OKLCH formats, which makes it useful even when you are not
                  copying the Tailwind match directly.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Search History:
                  </strong> Recently viewed colors are saved locally so you can
                  jump back to a previous comparison without retyping values.
                </li>
                <li>
                  <strong class="text-slate-800 dark:text-slate-200">
                    Premium UI:
                  </strong> A redesigned, responsive glassmorphism aesthetic with
                  split-view comparison, history controls, and richer analysis
                  panels than the original utility.
                </li>
              </ul>
              <p class="pt-2">
                Powered by <Link url="https://astro.build/">
                  <span
                    class="font-semibold text-indigo-500 hover:text-indigo-600 hover:underline dark:text-indigo-400 dark:hover:text-indigo-300"
                  >
                    Astro
                  </span>
                </Link> and <Link url="https://react.dev/">
                  <span
                    class="font-semibold text-indigo-500 hover:text-indigo-600 hover:underline dark:text-indigo-400 dark:hover:text-indigo-300"
                  >
                    React
                  </span>
                </Link>. Completely open source!
              </p>
              <div class="flex flex-wrap gap-3 pt-4">
                <Link url="https://github.com/JalilAbdullayev/hex-tailwind/">
                  <span
                    class="inline-flex items-center justify-center rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-md hover:bg-indigo-700 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all dark:bg-indigo-500 dark:hover:bg-indigo-400"
                  >
                    View this fork
                  </span>
                </Link>
                <Link url="https://github.com/mihailthebuilder/hex-tailwind">
                  <span
                    class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white shadow-md hover:bg-slate-800 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-slate-900 transition-all dark:bg-slate-700 dark:hover:bg-slate-600"
                  >
                    Original Repo
                  </span>
                </Link>
              </div>
            </div>
          </div>
        </section>
      </div>
      <section
        class="relative p-8 mt-12 mb-8 overflow-hidden border bg-indigo-50/70 dark:bg-indigo-950/20 border-indigo-100/50 dark:border-indigo-900/50 shadow-input rounded-3xl md:p-12"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 -mt-20 -mr-20 rounded-full pointer-events-none bg-purple-100/50 dark:bg-purple-900/20 blur-3xl"
        >
        </div>
        <div class="relative z-10 mx-auto text-center">
          <h2
            class="mb-3 text-3xl font-bold tracking-tight text-slate-800 dark:text-slate-100"
          >
            Questions or feedback?
          </h2>
          <p class="mb-8 text-lg text-slate-600 dark:text-slate-400">
            Have an idea on how to make this tool better? Let us know below.
          </p>
          <div
            class="p-6 text-left transition-shadow border border-white shadow-sm dark:border-slate-800 bg-white/70 dark:bg-slate-900/70 backdrop-blur-md md:p-8 rounded-2xl hover:shadow-md"
          >
            <FeedbackForm client:load />
          </div>
        </div>
      </section>
    </main>
    <footer
      class="py-12 text-sm font-medium text-center text-slate-500 dark:text-slate-400"
    >
      <p>Copyright Tuxedo Software {new Date().getFullYear()}</p>
    </footer>
    <script
      is:inline
      src="https://web3forms.com/client/script.js"
      async
      defer></script>
  </body>
</html>
